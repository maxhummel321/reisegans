# Travel Planner — shares the SAME Supabase project as Gänsemünchen.
# Copy to .env.local and fill in. .env.local is gitignored.

# Google Maps (browser key — restrict by HTTP referrer in Google Cloud)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Google Maps (server-only key for Places details + photo proxy — no referrer restriction)
GOOGLE_MAPS_SERVER_KEY=

# Supabase (identical values to the Gänsemünchen app — shared project)
NEXT_PUBLIC_SUPABASE_URL=https://scjasqaczdmpgvrdfuon.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
